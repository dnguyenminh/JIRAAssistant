# ═══════════════════════════════════════════════════════════════
# Jira Assistant — Git Ignore
# ═══════════════════════════════════════════════════════════════

# ── Secrets & Environment ──
.env
.env.*
!.env.example

# ── Screenshots (browser testing) ──
screenshots/

# ── Build outputs ──
build/
out/
bin/
*.jar
*.class

# ── Gradle ──
.gradle/
gradle/wrapper/gradle-wrapper.jar

# ── IDE ──
.idea/
*.iml
*.ipr
*.iws
.vscode/

# ── Kotlin ──
.kotlin/

# ── Node / JS ──
node_modules/
package-lock.json
yarn.lock

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Database ──
*.db
*.sqlite
data/

# ── Test outputs ──
test.properties
e2e-tests/target/
e2e-tests/build/
e2e-tests/bin/

# ── Proof of Concept ──
poc/

# ── Docker ──
docker-compose.override.yml
