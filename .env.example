# ═══════════════════════════════════════════════════════════════
# Jira Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit this file to git.

# ── Server ──
PORT=8080
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
ENCRYPTION_KEY=change-me-to-a-random-key-32chars!
STATIC_DIR=./frontend/build/kotlin-webpack/js/developmentExecutable

# ── PostgreSQL + pgvector ──
DATABASE_URL=jdbc:postgresql://localhost:5432/jira_assistant
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_SIZE=10
POSTGRES_DB=jira_assistant
POSTGRES_PORT=5432

# ── Jira Integration ──
JIRA_HOST=https://your-team.atlassian.net
JIRA_API_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ── Jira MCP Testing ──
JIRA_MCP_EMAIL=your-mcp-email@example.com
JIRA_MCP_TOKEN=your-mcp-jira-token

# ── AI Providers ──
# Ollama (local) — set OLLAMA_MAX_LOADED_MODELS=2 when running ollama serve
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Embedding model (for attachment semantic search)
# Run: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# LM Studio (local)
LM_STUDIO_ENDPOINT=http://localhost:1234
LM_STUDIO_MODEL=default

# Gemini CLI
GEMINI_CLI_PATH=/usr/local/bin/gemini
